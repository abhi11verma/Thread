{
  "key": "material-dark",
  "label": "Material",
  "meta": {
    "dark": true,
    "description": "Material Design 2 dark theme — #121212 base, elevation overlays, Teal 200 accent"
  },
  "tokens": {
    "global": {
      "radius": "4px",
      "radius-sm": "4px"
    },
    "surface": {
      "paper":   "#121212",
      "paper-2": "#1E1E1E",
      "paper-3": "#272727"
    },
    "text": {
      "ink":       "#E0E0E0",
      "ink-2":     "#B8B8B8",
      "ink-soft":  "#9E9E9E",
      "ink-faint": "#616161"
    },
    "border": {
